{
  "name": "ai-interaction-hub",
  "version": "2.0.8",
  "description": "Hub unificado para múltiplos chats de IA",
  "author": "Alessandro Willian",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predist": "npm run generate-icons",
    "dist": "electron-builder",
    "release": "electron-builder --publish always",
    "generate-icons": "node scripts/generate-icons.js",
    "test": "jest"
  },
  "devDependencies": {
    "electron": "^39.8.7",
    "electron-builder": "^26.0.12",
    "jest": "^30.3.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.alessandrowillian.aiinteractionhub",
    "productName": "AI Interaction Hub",
    "win": {
      "target": "nsis",
      "icon": "icons/app.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/hicolor/512x512/apps/aiinteractionhub.png",
      "category": "Network",
      "desktop": {
        "entry": {
          "StartupWMClass": "AI Interaction Hub"
        }
      },
      "executableName": "ai-interaction-hub",
      "maintainer": "Alessandro Willian <noreply@aiinteractionhub.local>"
    },
    "files": [
      "**/*",
      "!dist/",
      "!node_modules/"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "awilliansd",
        "repo": "ai-interaction-hub",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
